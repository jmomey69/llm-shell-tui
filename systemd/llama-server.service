[Unit]
Description=llama.cpp inference server (CUDA)
After=network.target

[Service]
Type=simple
Environment=PATH=/usr/local/cuda/bin:/usr/local/bin:/usr/bin:/bin
Environment=LD_LIBRARY_PATH=/home/peter/Documents/ai-assistant/ai-quant-platform/llama.cpp/build/bin
ExecStart=/home/peter/Documents/ai-assistant/ai-quant-platform/llama.cpp/build/bin/llama-server \
    -m /home/peter/Qwen3.6-27B-MTP-pi-tune-Q4_K_M.gguf \
    --jinja -ngl 55 --flash-attn on -c 16384 \
    --cache-type-k q8_0 --cache-type-v q8_0 \
    --temp 0.7 --top-p 0.8 --top-k 20 --min-p 0 \
    --presence-penalty 1.5 \
    --host 127.0.0.1 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
